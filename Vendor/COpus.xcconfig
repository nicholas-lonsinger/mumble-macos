// Build settings for the COpus static-library target (vendored libopus 1.5.2).
//
// Translated from Packages/COpus/Package.swift cSettings when libopus moved
// from a local SwiftPM package to a native Xcode target.

PRODUCT_NAME = COpus

ARCHS = arm64
ONLY_ACTIVE_ARCH = YES

MACOSX_DEPLOYMENT_TARGET = 26.0
SDKROOT = macosx
SUPPORTED_PLATFORMS = macosx

GCC_C_LANGUAGE_STANDARD = gnu17

// libopus's #include "config.h" finds our handwritten replacement here.
// The other entries replicate Package.swift cSettings.headerSearchPath().
HEADER_SEARCH_PATHS = $(SRCROOT)/Vendor/opus-config $(SRCROOT)/Vendor/opus $(SRCROOT)/Vendor/opus/include $(SRCROOT)/Vendor/opus/celt $(SRCROOT)/Vendor/opus/silk $(SRCROOT)/Vendor/opus/silk/float $(SRCROOT)/Vendor/opus/src

GCC_PREPROCESSOR_DEFINITIONS = $(inherited) OPUS_BUILD=1 HAVE_CONFIG_H=1

// libopus is upstream third-party C; suppress its diagnostics so they don't
// pollute the app's issue list. Matches Package.swift's .unsafeFlags(["-w"]).
OTHER_CFLAGS = $(inherited) -w

// We're a static library; don't try to codesign or strip the .a.
SKIP_INSTALL = YES
CODE_SIGNING_ALLOWED = NO
DEAD_CODE_STRIPPING = YES
EXECUTABLE_PREFIX = lib

// All warnings off (libopus uses many idioms current clang flags as warnings).
GCC_WARN_64_TO_32_BIT_CONVERSION = NO
CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO

// Disable Clang modules for the libopus compilation. Modules-on causes clang
// to scan the system Intel intrinsics modulemap when it parses kiss_fft.h /
// float_cast.h (which `#include <xmmintrin.h>` under `__SSE__`), and the
// _Builtin_intrinsics.intel.sse module's `requires feature "x86"` clause then
// errors on arm64 hosts — even though the include itself is gated and never
// fires. Plain preprocessing (no modules) respects the #if guard correctly.
//
// The Swift `import COpus` path is unaffected: consumers still pick up the
// hand-written module.modulemap via SWIFT_INCLUDE_PATHS on the app target.
CLANG_ENABLE_MODULES = NO

// File exclusions. PBXFileSystemSynchronizedBuildFileExceptionSet's
// `membershipExceptions` only matches individual files in Xcode 16, not
// directory paths, so directory-wide exclusions live here as fnmatch
// patterns instead. Mirrors the rationale in Packages/COpus/Package.swift's
// (now removed) `exclude:` array — see that history for per-section notes.
// fnmatch's `*` doesn't cross `/`, so each directory depth needs its own
// pattern. dnn/ goes 4 levels deep (dnn/torch/rdovae/packets/*.c).
EXCLUDED_SOURCE_FILE_NAMES = $(inherited) */celt/x86/* */silk/x86/* */silk/float/x86/* */dnn/* */dnn/*/* */dnn/*/*/* */dnn/*/*/*/* */silk/fixed/* */silk/fixed/*/* */celt/mips/* */silk/mips/* */celt/tests/* */silk/tests/* */tests/* */celt/dump_modes/* */doc/* */training/* */cmake/* */scripts/* */m4/* */meson/* */.github/*

